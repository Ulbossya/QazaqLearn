{
  "name": "qazaqlearn",
  "version": "0.1.0",
  "private": true,
  "packageManager": "pnpm@9.15.4",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev": "corepack pnpm --parallel dev",
    "build": "corepack pnpm run db:generate && corepack pnpm -r build",
    "start": "corepack pnpm run db:deploy && corepack pnpm run db:seed && corepack pnpm --filter @qazaqlearn/api start",
    "test": "corepack pnpm -r test",
    "test:api": "corepack pnpm --filter @qazaqlearn/api test",
    "test:web": "corepack pnpm --filter @qazaqlearn/web test",
    "prisma": "corepack pnpm --filter @qazaqlearn/api prisma",
    "db:generate": "corepack pnpm --filter @qazaqlearn/api prisma generate",
    "db:migrate": "corepack pnpm --filter @qazaqlearn/api prisma migrate dev",
    "db:deploy": "corepack pnpm --filter @qazaqlearn/api prisma migrate deploy",
    "db:seed": "corepack pnpm --filter @qazaqlearn/api prisma db seed"
  },
  "devDependencies": {
    "typescript": "^5.7.3"
  }
}
